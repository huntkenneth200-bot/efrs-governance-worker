{
  "name": "efrs-worker",
  "version": "1.0.0",
  "description": "EFRS Governance Suite Background Worker",
  "main": "dist/worker.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/worker.js",
    "dev": "ts-node src/worker.ts",
    "typecheck": "tsc --noEmit",
    "enqueue": "ts-node src/cli/enqueue-event.ts",
    "replay": "ts-node src/cli/replay-events.ts"
  },
  "dependencies": {
    "@aws-sdk/client-sqs": "^3.554.0",
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
